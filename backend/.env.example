PORT=3000
NODE_ENV=development

# FRONTEND_URL é a origem principal permitida pelo CORS.
# Em produção, usar a URL exata da Vercel, sem barra final.
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS permite múltiplas origens separadas por vírgula, útil para previews da Vercel.
FRONTEND_URLS=

# Use DATABASE_URL em Railway/Render quando a plataforma fornecer uma URL do PostgreSQL.
DATABASE_URL=postgresql://usuario:senha@host:porta/banco

# Alternativa local se não usar DATABASE_URL.
DB_HOST=localhost
DB_PORT=5433
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_NAME=picking_system
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Obrigatório: mínimo 32 caracteres. Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=coloque_uma_chave_segura_com_pelo_menos_32_caracteres
JWT_EXPIRES_IN=1d
JWT_ISSUER=stockroute-api
JWT_AUDIENCE=stockroute-client
